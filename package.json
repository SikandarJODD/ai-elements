{
	"name": "ai-elements",
	"private": true,
	"version": "0.0.5",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"build:ai-elements": "pnpm shadcn-svelte registry build ./ai-elements.json -o ./static/r",
		"build:prompt-kit": "pnpm shadcn-svelte registry build ./prompt-kit.json -o ./static/p",
		"jsrepo:build": "jsrepo build",
		"jsrepo:publish": "jsrepo publish",
		"jsrepo:publish:dry": "jsrepo publish --dry-run"
	},
	"devDependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.8.0",
		"@sveltejs/kit": "^2.56.1",
		"@sveltejs/vite-plugin-svelte": "latest",
		"@tailwindcss/typography": "^0.5.15",
		"@tailwindcss/vite": "^4.2.2",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"embla-carousel-svelte": "^8.6.0",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.7.1",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"svelte-meta-tags": "^4.4.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.0.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@tailwindcss/oxide",
			"esbuild"
		]
	},
	"dependencies": {
		"@ai-sdk/openai": "^3.0.5",
		"@ai-sdk/svelte": "^4.0.12",
		"@openrouter/ai-sdk-provider": "^2.5.0",
		"@shikijs/langs": "^4.0.2",
		"@shikijs/themes": "^4.0.2",
		"@sveltejs/adapter-vercel": "^6.3.0",
		"@xyflow/svelte": "^1.3.1",
		"ai": "^6.0.12",
		"dompurify": "^3.3.1",
		"isomorphic-dompurify": "2.25.0",
		"jsrepo": "^2.5.0",
		"marked": "^18.0.0",
		"mode-watcher": "^1.1.0",
		"nanoid": "^5.1.6",
		"package-manager-detector": "^1.3.0",
		"paneforge": "^1.0.2",
		"runed": "^0.37.1",
		"shiki": "^4.0.2",
		"svelte-sonner": "^1.0.5",
		"svelte-streamdown": "^3.0.1",
		"svelte-toolbelt": "^0.10.5",
		"zod": "^4.1.12"
	}
}
